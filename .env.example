# Required: get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: for recording leads and unknown questions via Pushover
# Get app token and user key at https://pushover.net/
PUSHOVER_TOKEN=your_pushover_app_token
PUSHOVER_USER=your_pushover_user_key

# Optional: display name for the chat agent (defaults to "You" if unset)
MY_NAME=Your Name
